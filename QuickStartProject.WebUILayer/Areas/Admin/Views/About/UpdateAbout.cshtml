@model QuickStartProject.WebUILayer.DTOs.AboutDTOs.ResultAboutDTO
@{
    ViewData["Title"] = "Hakkımızda Güncelle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pc-container">
    <div class="pc-content">
        <div class="page-header">
            <div class="page-block">
                <div class="row align-items-center">
                    <div class="col-md-12">
                        <div class="page-header-title">
                            <h5 class="m-b-10">Hakkımızda Güncelle</h5>
                        </div>
                        <ul class="breadcrumb">
                            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Ana Sayfa</a></li>
                            <li class="breadcrumb-item"><a href="javascript:void(0)">Hakkımızda</a></li>
                            <li class="breadcrumb-item" aria-current="page">Güncelle</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="ti ti-info-circle me-2"></i>Hakkımızda Bilgileri</h5>
                    </div>
                    <div class="card-body">
                        @if (TempData["ErrorData"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="ti ti-alert-circle me-2"></i>@TempData["ErrorData"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                        else if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="ti ti-check me-2"></i>@TempData["Success"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                        else if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="ti ti-alert-circle me-2"></i>@TempData["Error"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                        <form asp-area="Admin" asp-controller="About" asp-action="UpdateAbout" method="post">
                            <input type="hidden" name="Id" value="@Model.Id" />
                            <div class="row">
                                <div class="col-12 mb-3">
                                    <label class="form-label">Başlık</label>
                                    <input type="text" name="Title" value="@Model.Title" class="form-control" placeholder="Başlık" />
                                </div>
                                <div class="col-12 mb-3">
                                    <label class="form-label">Açıklama</label>
                                    <textarea name="Description" class="form-control" rows="4" placeholder="Açıklama">@Model.Description</textarea>
                                </div>
                                <div class="col-12 mb-3">
                                    <label class="form-label">Görseller</label>
                                    <input type="text" name="Images" value="@(Model.Images != null && Model.Images.Count > 0 ? Model.Images[0] : "")" class="form-control mb-1" placeholder="Görsel URL 1" />
                                    <input type="text" name="Images" value="@(Model.Images != null && Model.Images.Count > 1 ? Model.Images[1] : "")" class="form-control mb-1" placeholder="Görsel URL 2" />
                                    <input type="text" name="Images" value="@(Model.Images != null && Model.Images.Count > 2 ? Model.Images[2] : "")" class="form-control" placeholder="Görsel URL 3" />
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="ti ti-device-floppy me-1"></i>Kaydet
                                    </button>
                                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-light">İptal</a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

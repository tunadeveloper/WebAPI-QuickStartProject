@model QuickStartProject.WebUILayer.DTOs.ContactDTOs.ResultContactDTO
@{
    ViewData["Title"] = "İletişim Bilgilerini Güncelle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pc-container">
    <div class="pc-content">
        <div class="page-header">
            <div class="page-block">
                <div class="row align-items-center">
                    <div class="col-md-12">
                        <div class="page-header-title">
                            <h5 class="m-b-10">İletişim Bilgilerini Güncelle</h5>
                        </div>
                        <ul class="breadcrumb">
                            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Ana Sayfa</a></li>
                            <li class="breadcrumb-item"><a href="javascript:void(0)">İletişim</a></li>
                            <li class="breadcrumb-item" aria-current="page">Güncelle</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="ti ti-phone me-2"></i>İletişim Bilgileri</h5>
                    </div>
                    <div class="card-body">
                        @if (TempData["ErrorData"] != null)
                        {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="ti ti-alert-circle me-2"></i>@TempData["ErrorData"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                        }
                        else if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="ti ti-check me-2"></i>@TempData["Success"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        else if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="ti ti-alert-circle me-2"></i>@TempData["Error"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                            <form asp-area="Admin" asp-controller="Contact" asp-action="UpdateContact" method="post">
                                <input type="hidden" value="@Model.Id" name="Id"/>

                                <div class="row">
                                    <div class="col-12 mb-3">
                                        <label value="Title" class="form-label">Başlık</label>
                                        <input type="text" name="Title" value="@Model.Title" class="form-control" placeholder="İletişim bölümü başlığı" />
                                        <span asp-validation-for="Title" class="text-danger small"></span>
                                    </div>

                                    <div class="col-12 mb-3">
                                        <label value="Description" class="form-label">Açıklama</label>
                                        <textarea name="Description" class="form-control" rows="4" placeholder="Kısa açıklama metni">@Model.Description</textarea>
                                        <span asp-validation-for="Description" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label value="Address" class="form-label">Adres</label>
                                        <input type="text" value="@Model.Address" name="Address" class="form-control" placeholder="Adres" />
                                        <span asp-validation-for="Address" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label value="Phone" class="form-label">Telefon</label>
                                        <input type="text" value="@Model.Phone" name="Phone" class="form-control" placeholder="Telefon numarası" />
                                        <span asp-validation-for="Phone" class="text-danger small"></span>
                                    </div>

                                    <div class="col-12 mb-4">
                                        <label value="Email" class="form-label">E-posta</label>
                                        <input type="email" value="@Model.Email" name="Email" class="form-control" placeholder="ornek@email.com" />
                                        <span asp-validation-for="Email" class="text-danger small"></span>
                                    </div>

                                    <div class="col-12">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="ti ti-device-floppy me-1"></i>Kaydet
                                        </button>
                                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-light">İptal</a>
                                    </div>
                                </div>
                            </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
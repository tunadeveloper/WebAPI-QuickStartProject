@model List<QuickStartProject.WebUILayer.DTOs.FeaturedServiceDTOs.ResultFeaturedServiceDTO>
@{
    ViewData["Title"] = "Öne Çıkan Hizmetler";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pc-container">
    <div class="pc-content">
        <div class="page-header">
            <div class="page-block">
                <div class="row align-items-center">
                    <div class="col-md-12">
                        <div class="page-header-title">
                            <h5 class="m-b-10">Öne Çıkan Hizmetler</h5>
                        </div>
                        <ul class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/Admin/Dashboard/Index">Ana Sayfa</a></li>
                            <li class="breadcrumb-item"><a href="javascript:void(0)">Öne Çıkan Hizmetler</a></li>
                            <li class="breadcrumb-item" aria-current="page">Liste</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <h5 class="mb-0"><i class="ti ti-star me-2"></i>Öne Çıkan Hizmet Listesi</h5>
                        <a href="/Admin/FeaturedService/CreateFeaturedService" class="btn btn-primary btn-sm">
                            <i class="ti ti-plus me-1"></i>Yeni Ekle
                        </a>
                    </div>
                    <div class="card-body">
                        @if (TempData["ErrorData"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="ti ti-alert-circle me-2"></i>@TempData["ErrorData"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                        else if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="ti ti-check me-2"></i>@TempData["Success"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                        else if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="ti ti-alert-circle me-2"></i>@TempData["Error"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                        <div class="table-responsive">
                            <table class="table table-hover table-borderless mb-0">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>İkon</th>
                                        <th>Başlık</th>
                                        <th>Açıklama</th>
                                        <th class="text-end">İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.Id</td>
                                            <td>@item.Icon</td>
                                            <td>@item.Title</td>
                                            <td>@(item.Description != null && item.Description.Length > 50 ? item.Description.Substring(0, 50) + "..." : (item.Description ?? "-"))</td>
                                            <td class="text-end">
                                                <a href="/Admin/FeaturedService/UpdateFeaturedService/@item.Id" class="btn btn-sm btn-light">
                                                    <i class="ti ti-edit"></i>
                                                </a>
                                                <a href="/Admin/FeaturedService/DeleteFeaturedService/@item.Id" class="btn btn-sm btn-light text-danger" onclick="return confirm('Bu kaydı silmek istediğinize emin misiniz?');">
                                                    <i class="ti ti-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

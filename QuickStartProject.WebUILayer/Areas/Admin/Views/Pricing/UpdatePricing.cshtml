@model QuickStartProject.WebUILayer.DTOs.PricingDTOs.ResultPricingDTO
@{
    ViewData["Title"] = "Fiyat Güncelle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pc-container">
    <div class="pc-content">
        <div class="page-header">
            <div class="page-block">
                <div class="row align-items-center">
                    <div class="col-md-12">
                        <div class="page-header-title">
                            <h5 class="m-b-10">Fiyat Güncelle</h5>
                        </div>
                        <ul class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/Admin/Dashboard/Index">Ana Sayfa</a></li>
                            <li class="breadcrumb-item"><a href="/Admin/Pricing/Index">Fiyatlandırma</a></li>
                            <li class="breadcrumb-item" aria-current="page">Güncelle</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="ti ti-currency-dollar me-2"></i>Fiyat Bilgileri</h5>
                    </div>
                    <div class="card-body">
                        @if (TempData["ErrorData"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="ti ti-alert-circle me-2"></i>@TempData["ErrorData"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                        else if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="ti ti-check me-2"></i>@TempData["Success"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                        else if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="ti ti-alert-circle me-2"></i>@TempData["Error"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                        <form asp-area="Admin" asp-controller="Pricing" asp-action="UpdatePricing" method="post">
                            <input type="hidden" name="Id" value="@Model.Id" />
                            <div class="row">
                                <div class="col-12 mb-3">
                                    <label class="form-label">Ad</label>
                                    <input type="text" name="Name" value="@Model.Name" class="form-control" placeholder="Ad" />
                                </div>
                                <div class="col-12 mb-3">
                                    <label class="form-label">Açıklama</label>
                                    <textarea name="Description" class="form-control" rows="3" placeholder="Açıklama">@Model.Description</textarea>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Fiyat</label>
                                    <input type="text" name="Price" value="@Model.Price" class="form-control" placeholder="Fiyat" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Dönem</label>
                                    <input type="text" name="Period" value="@Model.Period" class="form-control" placeholder="Dönem" />
                                </div>
                                <div class="col-12 mb-3">
                                    <label class="form-label">Öne Çıkan</label>
                                    <input type="hidden" name="IsFeatured" value="false" />
                                    <input type="checkbox" name="IsFeatured" value="true" class="form-check-input" @(Model.IsFeatured ? "checked" : "") />
                                </div>
                                <div class="col-12 mb-3">
                                    <label class="form-label">Özellikler</label>
                                    <input type="text" name="Features" value="@(Model.Features != null && Model.Features.Count > 0 ? Model.Features[0] : "")" class="form-control mb-1" placeholder="Özellik 1" />
                                    <input type="text" name="Features" value="@(Model.Features != null && Model.Features.Count > 1 ? Model.Features[1] : "")" class="form-control mb-1" placeholder="Özellik 2" />
                                    <input type="text" name="Features" value="@(Model.Features != null && Model.Features.Count > 2 ? Model.Features[2] : "")" class="form-control mb-1" placeholder="Özellik 3" />
                                    <input type="text" name="Features" value="@(Model.Features != null && Model.Features.Count > 3 ? Model.Features[3] : "")" class="form-control mb-1" placeholder="Özellik 4" />
                                    <input type="text" name="Features" value="@(Model.Features != null && Model.Features.Count > 4 ? Model.Features[4] : "")" class="form-control" placeholder="Özellik 5" />
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="ti ti-device-floppy me-1"></i>Kaydet
                                    </button>
                                    <a href="/Admin/Pricing/Index" class="btn btn-light">İptal</a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

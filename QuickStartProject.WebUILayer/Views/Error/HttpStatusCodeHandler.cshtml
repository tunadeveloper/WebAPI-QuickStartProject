@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hata @ViewBag.StatusCode - QuickStart</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="stylesheet" href="/loginError/style.css">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>

<body>
    <div class="stars">
        <span class="star"></span>
        <span class="star"></span>
        <span class="star"></span>
        <span class="star"></span>
        <span class="star"></span>
        <span class="star"></span>
        <span class="star"></span>
        <span class="star"></span>
        <span class="star"></span>
        <span class="star"></span>
    </div>
    <div class="planet planet-1"></div>
    <div class="planet planet-2"></div>
    <div class="content">
        <div class="rocket-wrap">
            <span class="rocket" aria-hidden="true">🚀</span>
        </div>
        <h1 class="code">@ViewBag.StatusCode</h1>
        <p class="message">@ViewBag.ErrorMessage</p>
        <a href="/" class="btn-home">Ana Sayfaya Dön</a>
    </div>
</body>
</html>

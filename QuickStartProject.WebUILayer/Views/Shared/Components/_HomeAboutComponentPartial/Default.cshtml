@model QuickStartProject.WebUILayer.DTOs.AboutDTOs.ResultAboutDTO
<section id="about" class="about section">
    <div class="container">
        <div class="row gy-4">
            <div class="col-lg-6 content" data-aos="fade-up" data-aos-delay="100">
                <p class="who-we-are">Biz Kimiz</p>
                <h3>@Model.Title</h3>
                <p class="fst-italic">@Model.Description</p>
                <a href="#contact" class="read-more"><span>İletişime Geçin</span><i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="col-lg-6 about-images" data-aos="fade-up" data-aos-delay="200">
                <div class="row gy-4">
                    <div class="col-lg-6">
                        <img src="@Model.Images[0]" class="img-fluid" alt="">
                    </div>
                    <div class="col-lg-6">
                        <div class="row gy-4">
                            <div class="col-lg-12">
                                <img src="@Model.Images[1]" class="img-fluid" alt="">
                            </div>
                            <div class="col-lg-12">
                                <img src="@Model.Images[2]" class="img-fluid" alt="">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

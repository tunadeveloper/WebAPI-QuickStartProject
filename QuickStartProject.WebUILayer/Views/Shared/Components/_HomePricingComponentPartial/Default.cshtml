@model List<QuickStartProject.WebUILayer.DTOs.PricingDTOs.ResultPricingDTO>
@{
    var delay = 100;
}
<section id="pricing" class="pricing section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Fiyatlandırma</h2>
        <p>Her bütçeye ve ihtiyaca uygun esnek planlarımızla tanışın. Sürpriz maliyetlerle karşılaşmadan, işletmenizin büyüklüğüne en uygun paketi seçerek hemen başlayın.</p>
    </div>
    <div class="container">
        <div class="row gy-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-4" data-aos="zoom-in" data-aos-delay="@delay">
                    <div class="pricing-item @(item.IsFeatured ? "featured" : "")">
                        @if (item.IsFeatured)
                        {
                            <p class="popular">Popüler</p>
                        }
                        <h3>@item.Name</h3>
                        <p class="description">@item.Description</p>
                        <h4><sup>₺</sup>@item.Price<span> / @item.Period</span></h4>
                        <a href="#contact" class="cta-btn">Ücretsiz deneyin</a>
                        <p class="text-center small">Kredi kartı gerekmez</p>
                        <ul>
                            @foreach (var feature in item.Features)
                            {
                                <li><i class="bi bi-check"></i> <span>@feature</span></li>
                            }
                        </ul>
                    </div>
                </div>
                delay += 100;
            }
        </div>
    </div>
</section>

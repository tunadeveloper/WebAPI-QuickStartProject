@model List<QuickStartProject.WebUILayer.DTOs.ServiceDTOs.ResultServiceDTO>
@{
    var delay = 100;
    var colors = new[] { "item-cyan", "item-orange", "item-teal", "item-red", "item-indigo", "item-pink" };
    var idx = 0;
}
<section id="services" class="services section light-background">
    <div class="container section-title" data-aos="fade-up">
        <h2>Hizmetler</h2>
        <p>Ýţletmenizi geleceđe taţýmak için ihtiyacýnýz olan tüm dijital çözümleri, yenilikçi ve sonuç odaklý bir yaklaţýmla sunuyoruz.</p>
    </div>
    <div class="container">
        <div class="row g-5">
            @foreach (var item in Model)
            {
                <div class="col-lg-6" data-aos="fade-up" data-aos-delay="@delay">
                    <div class="service-item @(colors[idx % colors.Length]) position-relative">
                        <i class="@item.Icon icon"></i>
                        <div>
                            <h3>@item.Title</h3>
                            <p>@item.Description</p>
                            <a href="#contact" class="read-more stretched-link">Daha Fazla <i class="bi bi-arrow-right"></i></a>
                        </div>
                    </div>
                </div>
                delay += 100;
                idx++;
            }
        </div>
    </div>
</section>
